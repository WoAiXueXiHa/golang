# ---------------------------------------------------------------------------
# 环境变量与敏感凭证防线（强制本地留存，绝对禁止提交）
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
*.env
config.yaml
config.json
*.pem
*.key
*.pub

# ---------------------------------------------------------------------------
# Go 语言编译产物与临时文件
# ---------------------------------------------------------------------------
# 编译生成的本地可执行二进制文件（AMD64 / ARM64 裸指令流）
*.exe
*.exe~
*.dll
*.so
*.dylib
# 你的二进制构建目标名（可以根据你 go build -o 后面跟的名字自行补充）
method_app
method_analysis
app

# 汇编与反汇编调优生成的临时文本（如之前执行 objdump 生成的文件）
*.s
*.asm
*.asm~

# 单元测试生成的基准测试、CPU/内存性能分析产物
*.test
*.out
*.prof

# ---------------------------------------------------------------------------
# 本地开发工具链缓存（VS Code / Remote-SSH）
# ---------------------------------------------------------------------------
.vscode/
# 如果允许提交团队共享的 tasks.json 或 launch.json，可以解除下面的注释：
#!.vscode/tasks.json
#!.vscode/launch.json
#!.vscode/extensions.json

# JetBrains 系列（GoLand）缓存
.idea/
*.iws
*.iws~

# ---------------------------------------------------------------------------
# 操作系统级垃圾缓存
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
Thumbtacks.db
Desktop.ini

.claude/
CLAUDE.md